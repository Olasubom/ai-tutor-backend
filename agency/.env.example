OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database (optional; defaults to sqlite:///./ai_tutor.db)
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/ai_tutor

# Memory
VECTOR_STORE_DIR=./data/vector_store
SHORT_TERM_MAX_TURNS=20
VECTOR_TOP_K=8

# Security
API_AUTH_ENABLED=false
API_KEY=change_me
ALLOW_DEV_ENDPOINTS=false
DEV_TOKEN=change_me_dev

# Optional source ingestion keys
YOUTUBE_API_KEY=
