OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database (optional; defaults to sqlite:///./ai_tutor.db)
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/ai_tutor

# Memory
VECTOR_STORE_DIR=./data/vector_store
SHORT_TERM_MAX_TURNS=20
VECTOR_TOP_K=8

# Security
API_AUTH_ENABLED=false
API_KEY=change_me
ALLOW_DEV_ENDPOINTS=false
DEV_TOKEN=change_me_dev
# Required for JWT login/register — generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_string

# Google Sign-In — same Web Client ID as frontend VITE_GOOGLE_CLIENT_ID
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Optional source ingestion keys
YOUTUBE_API_KEY=

# Gmail SMTP (password reset emails)
# Use a Google App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_NAME=AITutor
SMTP_FROM_EMAIL=your.email@gmail.com
# Set to false in production so dev codes are never returned in API responses
SMTP_EXPOSE_DEV_CODE=true

# Admin bootstrap (first admin created on startup if none exists)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-secure-password
BOOTSTRAP_KEY=your-secret-key

# Uploaded learning materials
UPLOAD_DIR=uploads/materials
MAX_UPLOAD_SIZE_MB=50
